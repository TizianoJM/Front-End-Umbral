rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config/site
    // Fields: homeHeaderPhoto (string), externalLink (string)
    //
    // Collection: services
    // Fields: id (string), title (string), icon (string), description (string), features (list), image (string)
    //
    // Collection: projects
    // Fields: id (string), title (string), category (string), description (string), fullDescription (string), image (string), scope (list), specs (map), gallery (list)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "tizianominajo@gmail.com" && request.auth.token.email_verified == true));
    }

    // Site Config
    match /config/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users (for role storage)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
